# Supabase (URL + one publishable/anon key — required for browser + middleware)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Legacy JWT “anon” key (API Settings → anon public) — still widely used
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# New Supabase “publishable” key (sb_publishable_…) — dashboard may only show this
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional fallbacks
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role — solo servidor (importación masiva / admin API). Nunca NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Supabase Direct Connection (server-only)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Resend (server-only)
RESEND_API_KEY=re_your_api_key_here
# Verified sender domain in Resend (e.g. notifications@yourdomain.com) — required for outbound mail
RESEND_FROM_EMAIL=notifications@yourdomain.com

# App — use the real origin in production (SEO: canonical, OG, sitemap, JSON-LD)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Minors: profile self-edit of sensitive fields is blocked in Postgres when a tutor link exists (migration 015).
# Supabase Auth login email is not covered by that trigger; use an Auth hook or admin-only email change if you need the same rule for auth email.

# Vercel KV / Upstash (optional) — CSV import progress in admin. Create a KV or Redis store in Vercel → link env vars.
# Without these, import still works synchronously (no live row counter).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Cron (e.g. Vercel Cron → GET /api/cron/churn-inactivity) — protect the route
# CRON_SECRET=your-long-random-secret

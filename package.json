{
  "name": "goldenenglish",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "local": "bash scripts/run-local.sh",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "npm run clean && npm run local",
    "clean": "rm -rf .next",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "check:supabase-boundaries": "node scripts/check-supabase-boundaries.mjs",
    "masterdb:generate": "node scripts/generate-masterdb-from-migrations.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:full": "sh -c 'export VITEST_COVERAGE_FULL=1 && vitest run --coverage'",
    "lighthouse:smoke": "bash scripts/lighthouse-smoke.sh",
    "precommit": "npm run lint && npm run check:supabase-boundaries && node scripts/precommit-verify.mjs && npm run build && npm run test:coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vercel/kv": "^3.0.0",
    "geoip-country": "^5.0.202604142355",
    "i18n-iso-countries": "^7.14.0",
    "isbot": "^5.1.37",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-calendar": "^6.0.1",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-is": "^19.2.5",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "resend": "^4.0.0",
    "sanitize-html": "^2.17.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.1.0"
  }
}
